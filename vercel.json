{
  "version": 2,
  "installCommand": "npm install && npm --prefix client install",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...path].js": {
      "regions": ["gru1"],
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

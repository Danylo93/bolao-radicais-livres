# Copie para server/.env e preencha com seus dados.

# String de conexão do PostgreSQL (ex.: AWS RDS)
DATABASE_URL=postgresql://USUARIO:SENHA@SEU-ENDPOINT.rds.amazonaws.com:5432/bolao_rl

# Chave do painel do organizador (/admin)
ADMIN_KEY=troque-esta-chave

# Sincronização automática de placares (Copa 2026)
# Opção 1 — API-Football (recomendado em produção): https://www.api-football.com/
API_FOOTBALL_KEY=
# API_FOOTBALL_LEAGUE=1
# API_FOOTBALL_SEASON=2026

# Opção 2 — API pública alternativa (fallback se não houver chave acima)
# WORLD_CUP_API_URL=https://worldcup26.ir
# WORLD_CUP_API=disable

# Cron Vercel (protege /api/cron/sync) — gere uma string aleatória
CRON_SECRET=

# Intervalo mínimo entre syncs ao abrir o app (ms). Padrão: 5 min
# SYNC_INTERVAL_MS=300000

# Porta do servidor
PORT=4010

# Defina PGSSL=disable apenas para um Postgres local sem SSL
# PGSSL=disable

# Opcional: limite de conexões do pool. Em serverless/Vercel, use 1 ou deixe vazio.
# PG_POOL_MAX=1
